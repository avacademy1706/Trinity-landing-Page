# Trinity landing page — create this as .env.local (NOT renamed from example)
# Restart the dev server after any change here.

# Google Apps Script webhook (server-side post → Google Sheets)
TRINITY_SHEET_WEBHOOK=https://script.google.com/macros/s/PASTE_YOUR_SCRIPT_ID/exec

# HubSpot (optional — leave blank to skip)
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_GUID=

# Meta Pixel (client-side, optional — leave blank to disable)
NEXT_PUBLIC_META_PIXEL_ID=
